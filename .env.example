## Bora.app (monorepo) — template de variáveis de ambiente
#
# Copie para `apps/web/.env.local` (conforme README) e preencha com seus dados.
# NUNCA commite `.env.local` nem segredos reais.
#
# Exemplo:
#   cp .env.example apps/web/.env.local
#

## Database (PostgreSQL / Supabase)
# String de conexão Postgres (Supabase: Settings → Database → Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

## Supabase
# URL do projeto Supabase (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxx.supabase.co"

# Chave ANON pública (Project Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Chave SERVICE ROLE (Project Settings → API → service_role)
# Use SOMENTE no servidor (scripts/admin). Não use com prefixo NEXT_PUBLIC.
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

## Better-Auth
# Segredo da aplicação para assinar tokens/sessão
BETTER_AUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# URL pública do app (dev: http://localhost:3000, prod: https://seu-dominio.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

